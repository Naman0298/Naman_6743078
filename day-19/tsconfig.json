{
  "compilerOptions": {
    "module": "ES2022",
    "target": "ES2022",
    "types": ["node", "@playwright/test"],
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node"
  }
}